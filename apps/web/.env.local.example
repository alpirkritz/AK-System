# Copy this file to apps/web/.env.local and fill in the values.
# See root .env.example for documentation on each variable.

# Postgres (production): set DATABASE_URL. Leave unset for local SQLite.
# DATABASE_URL=postgresql://user:pass@host:5432/dbname
DATABASE_PATH=./data/ak_system.sqlite

NEXT_PUBLIC_APP_URL=http://localhost:3000

NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# NextAuth (Google sign-in) – same Google OAuth client as below
# Add redirect URI in Google Cloud Console: https://your-domain.com/api/auth/callback/google
NEXTAUTH_SECRET=
NEXTAUTH_URL=

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

GOOGLE_CALENDAR_CLIENT_ID=
GOOGLE_CALENDAR_CLIENT_SECRET=
GOOGLE_CALENDAR_REFRESH_TOKEN=

# Optional: comma-separated ICS feed URLs (Outlook, Google export, etc.)
ICS_FEED_URLS=

TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_CHAT_ID=

# Optional: set to 1 to send a short feed digest to Telegram after each cron sync
FEED_SEND_TELEGRAM_DIGEST=

# Optional: secret for protecting cron endpoints (e.g. /api/cron/feed-sync)
CRON_SECRET=

GEMINI_API_KEY=

# Anthropic (Trading Journal at /trading-journal) – https://console.anthropic.com/
ANTHROPIC_API_KEY=
# Optional override (default: claude-3-5-sonnet-20241022)
# ANTHROPIC_MODEL=

# Optional: for flight search tool (SerpAPI)
SERPAPI_KEY=
