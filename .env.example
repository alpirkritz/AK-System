# ─────────────────────────────────────────────────────────────────────────────
# AK System – Environment Variables
#
# Copy this file to apps/web/.env.local and fill in the values.
# File apps/web/.env.local is git-ignored and will never be committed.
# ─────────────────────────────────────────────────────────────────────────────

# ── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Optional encryption key for Next.js Server Actions (auto-generated if not set)
# NEXT_SERVER_ACTIONS_ENCRYPTION_KEY=

# ── Database (SQLite) ─────────────────────────────────────────────────────────
# Default: apps/web/data/ak_system.sqlite  (relative to apps/web)
DATABASE_PATH=./data/ak_system.sqlite

# ── Supabase ──────────────────────────────────────────────────────────────────
# Same Supabase project as Personal_Assistant (or create a new one at supabase.com)
# Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── NextAuth (Google sign-in) ──────────────────────────────────────────────
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET=your-nextauth-secret
# In production set to your app URL (e.g. https://your-app.up.railway.app)
# Add in Google Cloud Console redirect URI: ${NEXTAUTH_URL}/api/auth/callback/google
NEXTAUTH_URL=http://localhost:3000

# ── Google OAuth (for Calendar & sign-in) ───────────────────────────────────
# Google Cloud Console → APIs & Services → Credentials
# Enable: Google Calendar API. Add redirect URIs:
#   - ${NEXTAUTH_URL}/api/auth/callback/google  (sign-in)
#   - ${NEXT_PUBLIC_APP_URL}/api/auth/google-calendar/callback  (calendar)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Google Calendar OAuth (same credentials as above, or separate OAuth client)
GOOGLE_CALENDAR_CLIENT_ID=your-google-calendar-client-id
GOOGLE_CALENDAR_CLIENT_SECRET=your-google-calendar-client-secret
# Refresh token (obtained after first OAuth login, or copy from Personal_Assistant)
GOOGLE_CALENDAR_REFRESH_TOKEN=your-google-calendar-refresh-token

# ── Telegram Bot ──────────────────────────────────────────────────────────────
# Get from BotFather on Telegram: /newbot
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
# Your personal chat ID (only this chat ID can send commands to the bot)
# To find it: send a message to the bot, then run:
#   curl "https://api.telegram.org/bot<TOKEN>/getUpdates"
#   Look for: result[0].message.chat.id
TELEGRAM_ALLOWED_CHAT_ID=your-telegram-chat-id

# ── Gemini API ────────────────────────────────────────────────────────────────
# Get from Google AI Studio: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key
